# ─────────────────────────────────────────────────────────────
# Variables de entorno — Cloud Functions
#
# DESARROLLO LOCAL (Firebase Emulator):
#   Los handlers cargan automáticamente el .env RAÍZ del proyecto
#   (hg-catalog-ai/.env) a través del loadDotEnv interno.
#   NO es necesario crear functions/.env para el emulador local;
#   basta con tener el .env en la raíz con todas las variables.
#
#   NOTA: El parser de Firebase Emulator NO admite valores JSON
#   multilínea en .env (ej: FIREBASE_SA_KEY con private_key).
#   Por eso se usa el .env raíz directamente desde los handlers.
#
# PRODUCCIÓN (Firebase Console / Secret Manager):
#   Setear via CLI:
#     firebase functions:secrets:set FIREBASE_SA_KEY
#     firebase functions:secrets:set GEMINI_API_KEY
#   O desde Firebase Console > Functions > Environment variables.
# ─────────────────────────────────────────────────────────────

# Firebase Service Account (para Admin SDK — Firestore + Auth)
# IMPORTANTE: en producción usar Secret Manager, no env var plana
FIREBASE_SA_KEY={"type":"service_account","project_id":"hergon-catalog-ai","private_key_id":"..."}

# CORS — URL permitida en las respuestas de la Cloud Function
# En local usar: http://localhost:5000
# En producción: https://hergon-catalog-ai.web.app (o tu dominio)
ALLOWED_ORIGIN=http://localhost:5000

# ─────────────────────────────────────────────────────────────
# AI Generator
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=tu_gemini_api_key_aqui
# OPENROUTER_API_KEY=tu_openrouter_key_aqui
# ANTHROPIC_API_KEY=tu_anthropic_key_aqui
# OPENAI_API_KEY=tu_openai_key_aqui
# AI_MODEL=gemini-2.5-flash
