# ─────────────────────────────────────────────────────────────
# Variables de entorno — hg-catalog-ai
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas ".env" al repositorio.
# ─────────────────────────────────────────────────────────────

# Firebase Web API Key (solo necesaria en el frontend, usada por scripts/generate-env.js)
# Obtener en: https://console.cloud.google.com/apis/credentials?project=hergon-catalog-ai
FIREBASE_API_KEY=tu_firebase_api_key_aqui

# Firebase Service Account (para Cloud Functions — backend)
# Pegar el contenido completo del JSON en UNA sola línea (minificado/sin saltos de línea)
FIREBASE_SA_KEY={"type":"service_account","project_id":"hergon-catalog-ai","private_key_id":"..."}

# ─────────────────────────────────────────────────────────────
# AI Generator — Feature "Generar con IA"
# ─────────────────────────────────────────────────────────────
# Proveedor activo: openrouter | anthropic | openai | gemini
# Si se omite, se auto-detecta según cuál API key esté presente.
AI_PROVIDER=gemini

# Solo agrega la key del proveedor que vayas a usar:
GEMINI_API_KEY=tu_gemini_api_key_aqui
# OPENROUTER_API_KEY=tu_openrouter_key_aqui
# ANTHROPIC_API_KEY=tu_anthropic_key_aqui
# OPENAI_API_KEY=tu_openai_key_aqui

# Modelo a usar (opcional — si se omite usa el default del proveedor):
# AI_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────────────────────
# Firebase Hosting — CORS
# ─────────────────────────────────────────────────────────────
# URL permitida en cabeceras CORS de las Cloud Functions.
# En producción: https://hergon-catalog-ai.web.app (o tu dominio custom)
# En local:      http://localhost:5000
ALLOWED_ORIGIN=https://hergon-catalog-ai.web.app
